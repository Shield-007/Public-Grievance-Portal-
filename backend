def get_image_metadata(image_bytes):
    try:
        img = Image.open(io.BytesIO(image_bytes))
        exif_data = img._getexif()
        metadata = {}
        if exif_data:
            for tag, value in exif_data.items():
                decoded = TAGS.get(tag, tag)
                metadata[decoded] = value
        return metadata
    except Exception:
        return {}

def get_decimal_from_dms(dms, ref):
    degrees = float(dms[0])
    minutes = float(dms[1])
    seconds = float(dms[2])
    decimal = degrees + (minutes / 60.0) + (seconds / 3600.0)
    if ref in ['S', 'W']:
        decimal = -decimal
    return decimal

def ai_verify_v2(image_bytes, user_category, user_gps):
    # Tier 3: Quality Control (The "How Clear")
    nparr = np.frombuffer(image_bytes, np.uint8)
    img_cv = cv2.imdecode(nparr, cv2.IMREAD_COLOR)
    
    # Blur Detection (Laplacian Variance)
    gray = cv2.cvtColor(img_cv, cv2.COLOR_BGR2GRAY)
    laplacian_var = cv2.Laplacian(gray, cv2.CV_64F).var()
    if laplacian_var < 100:
        return False, "I couldn't clearly see the issue. Please ensure the photo is clear."

    # Light Check
    avg_intensity = np.mean(gray)
    if avg_intensity < 30:
        return False, "I couldn't clearly see the issue. It's too dark. Use a flash or report during day."

    # Tier 2: Metadata Verification
    metadata = get_image_metadata(image_bytes)
    # Timestamp Check (Last 24 hours)
    img_time_str = metadata.get('DateTimeOriginal') or metadata.get('DateTime')
    if img_time_str:
        try:
            img_time = datetime.strptime(img_time_str, '%Y:%m:%d %H:%M:%S')
            if datetime.now() - img_time > timedelta(hours=24):
                return False, "Photo is too old. Please take a fresh photo within the last 24 hours."
        except: pass

    # GPS Check (Match user's current GPS)
    gps_info = metadata.get('GPSInfo')
    if gps_info and user_gps:
        try:
            # Simple Euclidean distance for mock (50m ~ 0.00045 degrees)
            # In real system, use Haversine
            img_lat = get_decimal_from_dms(gps_info[2], gps_info[1])
            img_lon = get_decimal_from_dms(gps_info[4], gps_info[3])
            dist = np.sqrt((img_lat - user_gps[0])**2 + (img_lon - user_gps[1])**2)
            if dist > 0.0005: # Roughly 50 meters
                return False, "GPS mismatch. Please ensure you are at the spot of the issue."
        except: pass
    
    # Tier 1: Object Recognition (The "What") - YOLOv8 mock
    confidence = 0.85 
    if user_category.lower() == 'pothole' and confidence <= 0.75:
        return False, "I couldn't detect a clear pothole. Please ensure it's not a shadow."
    elif user_category.lower() == 'garbage' and confidence <= 0.75:
        return False, "I couldn't detect a clear garbage pile."
    
    return True, "AI Verified"

def ai_verify_grievance(title, description, category):
    # Mock Indic-BERT logic: Check if description matches category keywords
    keywords = {
        "garbage": ["waste", "trash", "garbage", "dump", "smell", "ಕಸ", "ತ್ಯಾಜ್ಯ"],
        "pothole": ["road", "hole", "pothole", "drive", "accident", "ರಸ್ತೆ", "ಗುಂಡಿ"],
        "water_leak": ["water", "pipe", "leak", "flood", "ನೀರು", "ಸೋರಿಕೆ"],
        "electricity": ["power", "light", "wire", "shock", "ವಿದ್ಯುತ್", "ಕರಂಟ್"]
    }
    
    desc_lower = description.lower()
    matches = any(kw in desc_lower for kw in keywords.get(category.lower(), []))
    
    if matches:
        return "AI Verified"
    return "Verification Pending"

# Database Fallback Logic
class MockCollection:
    def __init__(self):
        self.data = []
    async def insert_one(self, document):
        if "_id" not in document:
            document["_id"] = str(len(self.data) + 1)
        self.data.append(document)
        class Result:
            def __init__(self, id): self.inserted_id = id
        return Result(document["_id"])
    async def find_one(self, query):
        for item in self.data:
            match = True
            for k, v in query.items():
                if item.get(k) != v:
                    match = False
                    break
            if match:
                return item
        return None

class MockDB:
    def __init__(self):
        self.grievances = MockCollection()

