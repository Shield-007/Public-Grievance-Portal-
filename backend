@app.post("/grievances/", response_model=Grievance)
async def create_grievance(grievance: Grievance):
    # Generate BLR-ACK-[YEAR]-[RANDOM]
    year = datetime.now().year
    random_str = ''.join(random.choices(string.ascii_uppercase + string.digits, k=6))
    grievance.ack_id = f"BLR-ACK-{year}-{random_str}"
    
    # Run AI Verification (Indic-BERT mock)
    grievance.status = ai_verify_grievance(grievance.title, grievance.description, grievance.category)
    
    doc = grievance.dict()
    new_grievance = await db.grievances.insert_one(doc)
    
    # If using Mock, its' not a coroutine result but a Result object
    if hasattr(new_grievance, 'inserted_id'):
        inserted_id = new_grievance.inserted_id
    else: # Real Motor result
        inserted_id = new_grievance.inserted_id

    created_grievance = await db.grievances.find_one({"_id": inserted_id})
    return created_grievance

from fastapi import File, UploadFile, Form

@app.post("/verify-photo/")
async def verify_photo(
    file: UploadFile = File(...),
    category: str = Form(...),
    latitude: float = Form(None),
    longitude: float = Form(None)
):
    contents = await file.read()
    user_gps = (latitude, longitude) if latitude and longitude else None
    
    is_valid, message = ai_verify_v2(contents, category, user_gps)
    
    return {
        "valid": is_valid,
        "message": message,
        "maya_response": message if not is_valid else "Photo looks great! AI has verified the issue."
    }

@app.get("/grievances/{ack_id}", response_model=Grievance)
async def get_grievance(ack_id: str):
    grievance = await db.grievances.find_one({"ack_id": ack_id})
    if grievance:
        return grievance
    raise HTTPException(status_code=404, detail="Grievance not found")
